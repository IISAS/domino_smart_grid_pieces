{
    "SyntheticDataGeneratorPiece": {
        "name": "SyntheticDataGeneratorPiece",
        "dependency": {
            "dockerfile": null,
            "requirements_file": "requirements_0.txt"
        },
        "tags": [
            "SyntheticData",
            "Generator",
            "Simulation"
        ],
        "style": {
            "node_label": "Synthetic Data Generator",
            "node_type": "default",
            "node_style": {
                "backgroundColor": "#ebebeb"
            },
            "useIcon": true,
            "icon_class_name": "fa-solid:database",
            "iconStyle": {
                "cursor": "pointer"
            }
        },
        "description": "Generate synthetic tabular datasets for multiple smart-grid data domains in batch or realtime-like mode.",
        "container_resources": {
            "requests": {
                "cpu": 100,
                "memory": 128
            },
            "limits": {
                "cpu": 500,
                "memory": 512
            }
        },
        "input_schema": {
            "additionalProperties": true,
            "properties": {
                "dataset_type": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "One of: `solargis`, `microstep`, `shmu`, `okte`, `battery`, `machine` (aliases like `SoalrGIS Dataset` and `shmi` are also accepted).",
                    "title": "Dataset Type"
                },
                "output_mode": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "One of: `batch_sample`, `realtime_stream`.",
                    "title": "Output Mode"
                },
                "records_count": {
                    "default": 20,
                    "description": "Number of records to generate.",
                    "title": "Records Count",
                    "type": "integer"
                },
                "time_step_minutes": {
                    "default": 15,
                    "description": "Time step between generated records in minutes.",
                    "title": "Time Step Minutes",
                    "type": "integer"
                },
                "interval_ms": {
                    "default": 1000,
                    "description": "Realtime interval hint in milliseconds.",
                    "title": "Interval Ms",
                    "type": "integer"
                },
                "start_at": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Optional start datetime in ISO format.",
                    "title": "Start At"
                },
                "seed": {
                    "anyOf": [
                        {
                            "type": "integer"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Optional random seed for reproducible synthetic data.",
                    "title": "Seed"
                },
                "timezone_offset_hours": {
                    "default": 1.0,
                    "description": "Timezone offset used by SolarGIS-like records.",
                    "title": "Timezone Offset Hours",
                    "type": "number"
                }
            },
            "title": "InputModel",
            "type": "object"
        },
        "output_schema": {
            "properties": {
                "file_path": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "title": "Dataset file path"
                }
            },
            "title": "OutputModel",
            "type": "object"
        },
        "secrets_schema": null,
        "source_url": "https://github.com/IISAS/domino_smart_grid_pieces/tree/main/pieces/SyntheticDataGeneratorPiece"
    },
    "DataPreprocessingPiece": {
        "name": "DataPreprocessingPiece",
        "dependency": {
            "dockerfile": null,
            "requirements_file": "requirements_4.txt"
        },
        "tags": [
            "Template",
            "Data",
            "Preprocessing"
        ],
        "style": {
            "node_label": "Data Preprocessing",
            "node_type": "default",
            "node_style": {
                "backgroundColor": "#ebebeb"
            },
            "useIcon": true,
            "icon_class_name": "fa-solid:filter",
            "iconStyle": {
                "cursor": "pointer"
            }
        },
        "description": "Template piece for cleaning, validating, and preprocessing input data prior to feature engineering or training.",
        "container_resources": {
            "requests": {
                "cpu": 100,
                "memory": 128
            },
            "limits": {
                "cpu": 500,
                "memory": 512
            }
        },
        "input_schema": {
            "additionalProperties": true,
            "properties": {
                "preprocessing_option": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "One of: `none`, `prediction`, `correction`.",
                    "title": "Preprocessing Option"
                },
                "data_path": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Optional input data path.",
                    "title": "Data Path"
                },
                "save_data_path": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Optional output path.",
                    "title": "Save Data Path"
                },
                "test_size": {
                    "anyOf": [
                        {
                            "type": "number"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Optional split size.",
                    "title": "Test Size"
                },
                "keep_datetime": {
                    "anyOf": [
                        {
                            "type": "boolean"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Keep datetime column if supported.",
                    "title": "Keep Datetime"
                }
            },
            "title": "InputModel",
            "type": "object"
        },
        "output_schema": {
            "properties": {
                "message": {
                    "description": "Human-readable status message.",
                    "title": "Message",
                    "type": "string"
                },
                "artifacts": {
                    "description": "Optional outputs (e.g., cleaned dataset URI, dropped rows stats).",
                    "title": "Artifacts",
                    "type": "object"
                }
            },
            "required": [
                "message"
            ],
            "title": "OutputModel",
            "type": "object"
        },
        "secrets_schema": null,
        "source_url": "https://github.com/IISAS/domino_smart_grid_pieces/tree/main/pieces/DataPreprocessingPiece"
    }
}